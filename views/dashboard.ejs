<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link rel="stylesheet" href="/styles.css" />
</head>
<body>
  <header class="site-header small-header">
    <div class="overlay">
      <h1 class="logo">✈ GateBytes</h1>
      <p class="tagline">Flight-ready meal kit tracker</p>
      <nav class="nav-links">
        <a href="/">Home</a>
        <a href="/dashboard">Dashboard</a>
        <a href="/login">Login</a>
        <a href="/register">Register</a>
        <a href="/logout">Logout</a>
      </nav>
    </div>
  </header>

  <main class="main-content dashboard-main">
    <section class="dashboard-top">
      <div>
        <h2>Your Meal Kit Dashboard</h2>
        <p>Track your travel-ready food items and monitor low stock before your next trip.</p>
      </div>
      <a href="/add-item" class="primary-btn add-link">+ Add Item</a>
    </section>

    <section class="card-grid">
      <% if (items.length === 0) { %>
        <p>No items added yet. Click "Add Item" to get started.</p>
      <% } %>

      <% items.forEach((item) => { %>
        <article class="item-card">
          <div class="item-header">
            <h3><%= item.name %></h3>

            <% if (item.quantity <= item.lowStockThreshold) { %>
              <span class="badge low">Low Stock</span>
            <% } else { %>
              <span class="badge ok">In Stock</span>
            <% } %>
          </div>

          <p><strong>Quantity:</strong> <%= item.quantity %></p>
          <p><strong>Threshold:</strong> <%= item.lowStockThreshold %></p>
          <p><strong>Category:</strong> <%= item.category %></p>

          <% if (item.notes) { %>
            <p><strong>Notes:</strong> <%= item.notes %></p>
          <% } %>

          <div class="card-actions">
            <a href="/edit-item/<%= item._id %>" class="secondary-btn">Edit</a>
            <form action="/delete-item/<%= item._id %>" method="POST" style="display:inline;">
    <button type="submit" class="danger-btn">Delete</button>
  </form>
</div>
          </div>
        </article>
      <% }) %>
    </section>
  </main>
</body>
</html>